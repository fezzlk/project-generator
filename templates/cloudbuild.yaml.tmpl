steps:
  # Step 1: Docker build
  - name: "gcr.io/cloud-builders/docker"
    id: "build"
    args:
      - "build"
      # TODO: 必要に応じて --build-arg を追加
      - "-t=asia-northeast1-docker.pkg.dev/{{PROJECT_ID}}/{{REPO_NAME}}/{{SERVICE_NAME}}:$COMMIT_SHA"
      - "-t=asia-northeast1-docker.pkg.dev/{{PROJECT_ID}}/{{REPO_NAME}}/{{SERVICE_NAME}}:latest"
      - "."

  # Step 2: Push image to Artifact Registry
  - name: "gcr.io/cloud-builders/docker"
    id: "push"
    waitFor: ["build"]
    args:
      - "push"
      - "--all-tags"
      - "asia-northeast1-docker.pkg.dev/{{PROJECT_ID}}/{{REPO_NAME}}/{{SERVICE_NAME}}"

  # Step 3: Deploy to Cloud Run
  - name: "gcr.io/google.com/cloudsdktool/cloud-sdk"
    id: "deploy"
    waitFor: ["push"]
    entrypoint: "gcloud"
    args:
      - "run"
      - "deploy"
      - "{{SERVICE_NAME}}"
      - "--image=asia-northeast1-docker.pkg.dev/{{PROJECT_ID}}/{{REPO_NAME}}/{{SERVICE_NAME}}:$COMMIT_SHA"
      - "--region={{REGION}}"
      - "--memory=512Mi"
      - "--cpu=1"
      - "--min-instances=0"
      - "--max-instances=10"
      - "--allow-unauthenticated"
      - "--service-account={{SERVICE_NAME}}-run@{{PROJECT_ID}}.iam.gserviceaccount.com"
      # TODO: 環境変数を設定
      # - "--set-env-vars=KEY=VALUE"
      # TODO: Secret Managerのシークレットを設定
      # - "--update-secrets=ENV_VAR=secret-name:latest"

options:
  logging: CLOUD_LOGGING_ONLY
  substitutionOption: ALLOW_LOOSE
